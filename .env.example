# Copy to .env and fill in your credentials.
# On Railway, set these as environment variables in the dashboard.
USER_EMAIL=
USER_PASSWORD=
API_TOKEN=

# ── Notion Calendar integration ──────────────────────────────────────────────
# 1. Go to https://www.notion.so/my-integrations → New integration
#    Give it a name (e.g. "Room Booker"), select your workspace, save.
#    Copy the "Internal Integration Secret" → paste below.
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 2. Open the Notion database you want Notion Calendar to read from.
#    The URL looks like:
#      https://www.notion.so/<workspace>/<DATABASE_ID>?v=...
#    Copy the 32-char hex ID and paste below (hyphens optional).
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx